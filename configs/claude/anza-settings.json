{
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "theme": "auto",
  "effortLevel": "xhigh",
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/configs/claude/statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/format.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh done" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh start" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh stop" }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh stop" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh stop" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "~/dotfiles/configs/claude/hooks/tmux-state.sh notify" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)"
    ]
  }
}
