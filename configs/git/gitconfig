[alias]
	# View abbreviated SHA, description, and history graph of the latest 20 commits.
	l = log --pretty=oneline -n 20 --graph --abbrev-commit
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --

	# View the current working tree status using the short format.
	s = status -s

	# Show the diff between the latest commit and the current state.
	d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"
	df = diff --color --color-words --abbrev

	# Structural (AST-aware) diffs via difftastic, on demand — keeps delta as
	# the default pager. dft = working-tree diff; dlog = per-commit history.
	dft = -c diff.external=difft diff
	dlog = -c diff.external=difft log -p --ext-diff

	# List aliases.
	aliases = config --get-regexp alias

	# Amend the currently staged files to the latest commit.
	amend = commit --amend --reuse-message=HEAD

	clean-branches = !"git fetch --prune && git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -D"

[color "diff"]
	meta = yellow bold
	commit = green bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse
	newMoved = cyan
	oldMoved = blue

[color "status"]
	added = yellow
	untracked = cyan

[diff]
	# Detect copies as well as renames.
	renames = copies
	# Cleaner hunk boundaries than the default Myers algorithm.
	algorithm = histogram
	# Detect moved lines (pairs with the color "diff" newMoved/oldMoved above).
	colorMoved = default

[diff "bin"]
	# Use `hexdump` to diff binary files.
	textconv = hexdump -v -C

[help]
	# Automatically correct and execute mistyped commands.
	autocorrect = 1

[user]
	email = hello@quentinkniep.com
	name = Quentin Kniep

[push]
	default = current
	# No more `--set-upstream` on the first push of a new branch.
	autoSetupRemote = true
[pull]
	rebase = true
[init]
	defaultBranch = main
[core]
	excludesfile = /Users/qkniep/.gitignore_global
	# Syntax-highlighted diffs in the CLI and inside lazygit.
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	# Show the common ancestor in conflict markers (easier 3-way resolution).
	conflictStyle = zdiff3
[rerere]
	# Record conflict resolutions and replay them on repeated rebases.
	enabled = true
	autoupdate = true
[commit]
	# Include the full diff in the commit-message editor.
	verbose = true
[branch]
	# Most-recently-committed branches first in `git branch`.
	sort = -committerdate
[column]
	ui = auto
